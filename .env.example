# ============================================
# CONFIGURATION DE L'ENVIRONNEMENT
# ============================================
# Ce fichier est un template. Copiez-le vers .env.local pour le développement.
# Les variables de production sont configurées dans Vercel Dashboard.
#
# IMPORTANT: Ne jamais commiter de vraies credentials dans ce fichier !

# ============================================
# SUPABASE
# ============================================
# Créez un projet sur https://supabase.com
# Récupérez ces valeurs dans: Project Settings > API
#
# Pour le DÉVELOPPEMENT: Utilisez votre projet Supabase DEV
# Pour la PRODUCTION: Configurez dans Vercel (pas ici)

VITE_SUPABASE_URL=https://votre-projet-dev.supabase.co
VITE_SUPABASE_ANON_KEY=votre-anon-key-dev

# ============================================
# ADMINISTRATION
# ============================================
# Liste des emails admin séparés par des virgules
# En dev, mettez votre propre email

VITE_ADMIN_EMAILS=votre-email@example.com

# ============================================
# ONESIGNAL (Push Notifications)
# ============================================
# Créez un compte sur https://onesignal.com
# Optionnel en développement (laisser vide si non utilisé)

VITE_ONESIGNAL_APP_ID=
